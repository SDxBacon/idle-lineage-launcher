<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="idle-lineage-launcher"
        Arguments=""
        InstallLocation="C:\Program Files\SDxBacon\IdleLineageLauncher">
    </Installer>
    <PackageInformation
        PackageName="IdleLineageLauncher"
        PackageDisplayName="IdleLineageLauncher"
        PublisherName="CN=SDxBacon"
        PublisherDisplayName="SDxBacon"
        Version="0.1.0.0"
        PackageDescription="Desktop launcher for idle-lineage-class">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.sdxbacon.idle-lineage-launcher"
                Description="Desktop launcher for idle-lineage-class"
                DisplayName="IdleLineageLauncher"
                ExecutableName="idle-lineage-launcher"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>IdleLineageLauncher</DisplayName>
            <PublisherDisplayName>SDxBacon</PublisherDisplayName>
            <Description>Desktop launcher for idle-lineage-class</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="idle-lineage-launcher.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
